{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(uv:*)",
      "Bash(pytest:*)",
      "Bash(make:*)",
      "Bash(brew:*)",
      "Bash(npm run:*)",
      "Bash(docker ps:*)",
      "Bash(docker logs:*)",
      "Bash(pbcopy)",
      "Bash(pbpaste)",
      "Bash(which:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(tree:*)",
      "Bash(realpath:*)",
      "Bash(dirname:*)",
      "Bash(basename:*)",
      "Bash(md5:*)",
      "Bash(shasum:*)",
      "Bash(find:*)",
      "Bash(wc:*)",
      "Read(~/.zshrc)",
      "Read(~/.zshenv)",
      "Read(~/.functions)",
      "Read(~/.aliases)",
      "Read(~/Code/**)",
      "WebFetch",
      "WebSearch",
      "Edit",
      "mcp__linear-server__list_issues",
      "mcp__notion-private-server__notion-fetch",
      "mcp__notion-private-server__notion-search",
      "mcp__notion-everycure-server__notion-fetch",
      "mcp__notion-everycure-server__notion-search",
      "mcp__notion__notion-*",
      "mcp__notion__notion-*",
      "mcp__plugin_context7_context7__*",
      "mcp__plugin_serena_serena__*"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/secrets/**)",
      "Read(**/.secrets/**)",
      "Read(**/credentials*)",
      "Bash(rm -rf /)"
    ]
  },
  "enabledPlugins": {
    "claude-hud@claude-hud": true
  },
  "statusLine": {
    "type": "command",
    "command": "bash -c '\"/opt/homebrew/bin/node\" \"$(ls -td ~/.claude/plugins/cache/claude-hud/claude-hud/*/ 2>/dev/null | head -1)dist/index.js\"'"
  },
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ]
    }
  }
}